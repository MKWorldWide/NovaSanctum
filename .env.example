# Search Integrations (server-side)
# Google Programmable Search (Custom Search Engine)
# Create a CSE at https://programmablesearchengine.google.com/
GOOGLE_CSE_ID=
GOOGLE_API_KEY=

# Optional: Comma-separated list of allowed/high-trust domains for web results filtering
# Example: nature.com,sciencemag.org,nih.gov,arxiv.org,ieee.org,acm.org,cell.com,mit.edu,stanford.edu
SEARCH_ALLOWED_DOMAINS=

# Adaptive learning feature flags
NS_ADAPTIVE_LEARNING=true
NS_BYO_GENERATION=true
NS_OPT_IN_TELEMETRY=true

# BYO generation defaults (OpenAI-compatible API)
NS_BYO_BASE_URL=https://api.openai.com/v1
NS_BYO_MODEL=gpt-4o-mini
